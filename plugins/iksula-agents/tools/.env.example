# Iksula agent toolkits — environment variables (NAMES ONLY; never commit real values).
# Copy the variable NAMES, then set real values in YOUR OWN shell session — not in any
# committed file. Each operator uses THEIR OWN accounts, never someone else's.
#
#   PowerShell:  $env:WOODPECKER_AGENT_BUILD = "on"
#   Git Bash / macOS / Linux:  export WOODPECKER_AGENT_BUILD=on

# --- Lead Gen (Woodpecker) -----------------------------------------------------
# Your Woodpecker API key (from your own Woodpecker account: Settings → API & Integrations).
WOODPECKER_API_KEY=
# Master build switch. Anything other than "on" = the agent makes ZERO write calls.
WOODPECKER_AGENT_BUILD=off
# Comma-separated ids of warmed, isolated secondary-domain mailboxes the agent MAY use.
# Empty = the agent cannot build (the correct state until a warmed cold-send mailbox exists).
WOODPECKER_ALLOWED_MAILBOX_IDS=

# --- Growth Hacker -------------------------------------------------------------
# Publish switch. Anything other than "on" = every publish action is held.
GROWTH_PUBLISH=off
